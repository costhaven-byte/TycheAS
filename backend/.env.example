# ── Lucrator backend environment ──────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Runtime
PORT=5000
NODE_ENV=development

# Frontend origins allowed through CORS
FRONTEND_URL=http://localhost:5173
PRODUCTION_FRONTEND_URL=https://lucrator.vercel.app

# Backend API key — the frontend sends this as the `x-api-key` header on every
# request. Generate a strong random value. REQUIRED in production (the API
# refuses to run open). Example generator: node -e "console.log('lucrator_sk_'+require('crypto').randomBytes(24).toString('hex'))"
API_KEY=generate_a_strong_random_key_here

# ── Chatbot LLM provider (powers the website widget AND Instagram/Messenger DMs) ──
# Provider-agnostic: any OpenAI-compatible endpoint works. Set these three:
#   CHATBOT_API_KEY   server-side only, never exposed to the browser
#   CHATBOT_BASE_URL  the OpenAI-compatible base URL
#   CHATBOT_MODEL     a model slug valid for that provider
# Examples:
#   OpenRouter → key from https://openrouter.ai/keys
#     CHATBOT_BASE_URL=https://openrouter.ai/api/v1
#     CHATBOT_MODEL=anthropic/claude-haiku-4.5
#   Gemini → key from https://aistudio.google.com/apikey
#     CHATBOT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#     CHATBOT_MODEL=gemini-2.0-flash
CHATBOT_API_KEY=your_llm_api_key_here
CHATBOT_BASE_URL=https://openrouter.ai/api/v1
CHATBOT_MODEL=anthropic/claude-haiku-4.5
# Optional OpenRouter-only attribution headers (ignored for other providers).
# OPENROUTER_SITE_URL=https://lucrator.vercel.app
# OPENROUTER_APP_NAME=Lucrator FAQ Bot
# CHATBOT_QUESTION_LIMIT=5             # questions per visitor IP before steering to a free audit
# CHATBOT_WINDOW_MS=86400000          # window the per-IP cap resets over (24h)
# CHATBOT_AGENT_NAME=Lucri            # name the booking/buying agent signs calendar entries with
# TRUST_PROXY=1                        # proxies in front of the app (Render/Vercel set X-Forwarded-For)

# ── Client Platform (booking/buying agent → client's Google Sheet) ──
# The chatbot's agent writes bookings/sales into a client's Google Sheet via the
# multi-tenant Platform (google/Platform.gs), deployed ONCE for all clients.
#   APPS_SCRIPT_URL  the Platform Web App /exec URL
#   CRM_API_TOKEN    the ADMIN token printed by Platform setup() (writes to any client)
#   CRM_CLIENT_ID    which client this backend books/sells for (from `provision`)
# Leave any blank to keep the bot in FAQ-only mode (it chats but won't book/sell).
APPS_SCRIPT_URL=
CRM_API_TOKEN=
CRM_CLIENT_ID=

# ── Meta / Graph API ──
# Long-lived user (or IG) access token used by MetaService.
META_USER_ACCESS_TOKEN=your_meta_access_token_here

# App credentials from the Meta Developer dashboard (Settings → Basic).
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Target account/page IDs.
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Optional: dedicated Page access token (recommended for FB Page publishing and
# required for Instagram/Messenger DM features). Leave blank to fall back to the
# user token above.
FACEBOOK_PAGE_ACCESS_TOKEN=

# Optional overrides (sensible defaults applied if omitted).
# GRAPH_API_BASE_URL=https://graph.facebook.com
# GRAPH_API_VERSION=v21.0

# ── Webhooks ──
# A secret string you invent; you'll paste the same value into Meta's webhook
# setup so the verification handshake matches.
WEBHOOK_VERIFY_TOKEN=choose_a_random_string_here
# Auto-reply to new inbound DMs with a welcome message (true/false).
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MESSAGE=Hi 👋 Thanks for reaching out! Learn more at https://yourwebsite.com
