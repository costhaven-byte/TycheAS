# Dependencies — NEVER share these across machines.
# They contain OS-native binaries (esbuild, rollup, tailwind) that are
# compiled per-platform and break when copied between Mac and Windows.
node_modules/

# Build output — regenerated by `npm run build`.
dist/

# Vite cache
.vite/
*.local

# Logs
*.log
npm-debug.log*

# Per-machine Claude Code settings (machine-specific paths, PATH hacks, etc.)
.claude/settings.local.json

# OS / sync cruft
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini        # Windows / OneDrive
$RECYCLE.BIN/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
