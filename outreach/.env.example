# ---- Google Places API (New) ----
# Enable "Places API (New)" in your Google Cloud project, then restrict the key.
GOOGLE_PLACES_API_KEY=

# ---- Sending (Gmail SMTP via App Password) ----
# The Gmail/Workspace address the App Password belongs to.
GMAIL_USER=
# 16-char App Password from https://myaccount.google.com/apppasswords (spaces are fine).
GMAIL_APP_PASSWORD=

# ---- Signature / legal footer ----
# Shown in the signature and required on the unsubscribe line (CAN-SPAM).
SENDER_NAME=
REPLY_TO=
# A real physical mailing address OR registered business name + city.
MAILING_ADDRESS=

# ---- Throttling (safe defaults; your own Outreach playbook says 50-75/day) ----
DAILY_SEND_CAP=40
# Random delay window between sends, in seconds.
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=90
